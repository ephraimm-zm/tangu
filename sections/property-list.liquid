{% liquid
  if section.settings.collection != blank
    assign section_collection = collections[section.settings.collection]
    assign desktop_items = section.settings.desktop_items_to_show
    assign mobile_items = section.settings.mobile_items_to_show
    assign max_items = desktop_items
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-property-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
  data-testid="property-list"
>
  <div class="section-property-list__content">
    {%- content_for 'blocks' -%}
  </div>

  {% if section_collection == null %}
    {% assign section_collection = "" %}
    {% for i in (1..max_items) %}
      {% assign section_collection = section_collection | append: ', ' %}
    {% endfor %}
    {% assign section_collection = section_collection | split: ',' %}
  {% endif %}

  {% capture list_items %}
    {% for product in section_collection.products limit: max_items %}
      <div class="property-list__item">
        {% content_for 'block', type: '_property-card', id: 'static-property-card', closest.product: product %}
      </div>
      {% unless forloop.last %}
        <!--@list/split-->
      {% endunless %}
    {% endfor %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    carousel_ref: 'propertyList',
    slide_count: max_items,
    content_type: 'products',
    test_id: 'properties-list-grid'
  %}
</div>

{% schema %}
{
  "name": "t:sections.property_list.name",
  "class": "ui-test-property-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.property_list.settings.collection.label"
    },
    {
      "type": "header",
      "content": "t:sections.property_list.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.property_list.settings.heading.label",
      "info": "t:sections.property_list.settings.heading.info"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "t:sections.property_list.settings.heading_size.label",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "desktop_items_to_show",
      "label": "t:sections.property_list.settings.desktop_items_to_show.label",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "mobile_items_to_show",
      "label": "t:sections.property_list.settings.mobile_items_to_show.label",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "t:sections.property_list.settings.header__layout.content"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:sections.property_list.settings.layout_type.label",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.property_list.settings.layout_type.options.grid"
        },
        {
          "value": "carousel",
          "label": "t:sections.property_list.settings.layout_type.options.carousel"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:sections.property_list.settings.carousel_on_mobile.label",
      "default": true
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.property_list.settings.columns.label",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:sections.property_list.settings.mobile_columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.property_list.settings.mobile_columns.options.one"
        },
        {
          "value": "2",
          "label": "t:sections.property_list.settings.mobile_columns.options.two"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "t:sections.property_list.settings.mobile_card_size.label",
      "options": [
        {
          "value": "44cqw",
          "label": "t:sections.property_list.settings.mobile_card_size.options.two"
        }
      ],
      "default": "44cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:sections.property_list.settings.columns_gap.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "header",
      "content": "t:sections.property_list.settings.header__badge.content"
    },
    {
      "type": "text",
      "id": "badge_tag",
      "label": "t:sections.property_list.settings.badge_tag.label",
      "info": "t:sections.property_list.settings.badge_tag.info",
      "default": "guest-favorite"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:sections.property_list.settings.badge_text.label",
      "default": "Guest favorite"
    },
    {
      "type": "text",
      "id": "duration_text",
      "label": "t:sections.property_list.settings.duration_text.label",
      "default": "for 2 nights"
    },
    {
      "type": "header",
      "content": "t:sections.property_list.settings.header__design.content"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:sections.property_list.settings.section_width.label",
      "options": [
        {
          "value": "page-width",
          "label": "t:sections.property_list.settings.section_width.options.page"
        },
        {
          "value": "full-width",
          "label": "t:sections.property_list.settings.section_width.options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:sections.property_list.settings.gap.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.property_list.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:sections.property_list.settings.padding_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:sections.property_list.settings.padding_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "t:sections.property_list.settings.card_border_radius.label",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "t:sections.property_list.presets.name",
      "category": "t:sections.property_list.presets.category",
      "settings": {
        "collection": "",
        "layout_type": "carousel",
        "carousel_on_mobile": true,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 16,
        "section_width": "page-width",
        "gap": 12,
        "color_scheme": "scheme-1",
        "padding-block-start": 40,
        "padding-block-end": 40
      },
      "blocks": {
        "group_header": {
          "type": "group",
          "name": "t:sections.property_list.blocks.header.name",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "center",
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 12,
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "custom_height": 100,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "background_media": "none",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "heading": {
              "type": "text",
              "name": "t:sections.property_list.blocks.heading.name",
              "settings": {
                "text": "Popular homes in Cape Town",
                "type_preset": "h3",
                "font": "var(--font-body--family)",
                "wrap": "pretty",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left"
              }
            }
          },
          "block_order": ["heading"]
        },
        "static-property-card": {
          "type": "_property-card",
          "name": "t:sections.property_list.blocks.property_card.name",
          "static": true,
          "settings": {
            "inherit_color_scheme": true,
            "color_scheme": "",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 12
          }
        }
      },
      "block_order": ["group_header"]
    }
  ]
}
{% endschema %}
